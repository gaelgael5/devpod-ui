# Configuration du déploiement distant
# Copier ce fichier vers scripts\.env.remote-deploy et remplir les valeurs.
# NE JAMAIS committer scripts\.env.remote-deploy — il contient des secrets.

# Cible SSH
REMOTE_HOST=docker-dev.home.lan
REMOTE_PORT=22
REMOTE_USER=root

# Authentification — choisir UNE méthode :

# Option A : clé SSH (recommandé) — chemin Windows vers la clé privée
REMOTE_KEY=~\.ssh\id_shellia
# REMOTE_PASSWORD=

# Option B : mot de passe (nécessite plink / PuTTY installé)
# REMOTE_KEY=
# REMOTE_PASSWORD=mot-de-passe-ici

# Nombre de lignes de logs affichées après le démarrage (défaut : 80)
# LOG_LINES=80
