# Configuration du déploiement distant — VM portail workspace
# Copier ce fichier vers scripts\.env.portail-dev.remote-deploy et remplir les valeurs.
# NE JAMAIS committer scripts\.env.portail-dev.remote-deploy (contient des secrets).
#
# Utilisation :
#   .\scripts\remote-deploy.ps1 portail-dev
#
# Prérequis côté VM : Debian 12, Docker Engine installé, accès SSH root.
# Créer la VM avec : scripts\clone-vm-node.sh <VMID> --name portail-dev --ip <IP>/24 --gw <GW>

# ─── Cible SSH ────────────────────────────────────────────────────────────────
REMOTE_HOST=192.168.x.x
REMOTE_PORT=22
REMOTE_USER=root
REMOTE_KEY=~\.ssh\id_ed25519
# REMOTE_PASSWORD=

# ─── Déploiement ──────────────────────────────────────────────────────────────
BRANCH=main
APP_DIR=/opt/workspace-portal
COMPOSE_FILE=deploy/docker-compose.yml
DEPLOY_SCRIPT=./scripts/deploy-portal.sh
LOG_LINES=80

# ─── Variables du portail (passées à deploy-portal.sh) ───────────────────────
PORTAL_BASE_DOMAIN=dev.yoops.org
PORTAL_EXTERNAL_URL=https://dev.yoops.org
PORTAL_OIDC_ISSUER=https://security.yoops.org/realms/yoops
PORTAL_OIDC_CLIENT_ID=workspace-portal

# Secret du client Keycloak :
#   Keycloak → Clients → workspace-portal → Credentials → Client secret
OIDC_CLIENT_SECRET=
