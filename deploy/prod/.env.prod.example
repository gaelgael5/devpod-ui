# deploy/prod/.env.prod.example — gabarit du /data/.env de PRODUCTION.
# prod-deploy.sh copie ce fichier en /data/.env (chmod 600) au premier lancement,
# puis génère les valeurs AUTO marquées ci-dessous. Toute valeur déjà présente
# n'est JAMAIS réécrite (relances idempotentes).
#
# Deux familles de variables :
#   [AUTO]  — générées par prod-deploy.sh si vides (surchargeables : mettre une valeur ici).
#   [ADMIN] — credentials externes : à renseigner À LA MAIN (ne peuvent pas être générés).

# ─── Base de données ──────────────────────────────────────────────────────────
# [AUTO] générées aléatoirement au premier lancement.
POSTGRES_USER=
POSTGRES_PASSWORD=
# [AUTO] construite à partir des deux variables ci-dessus.
DATABASE_URL=

# ─── Vault ────────────────────────────────────────────────────────────────────
# [AUTO] clé de chiffrement 32 bytes (64 chars hex), générée UNE SEULE FOIS.
# ATTENTION : ne jamais la modifier après coup — tous les secrets chiffrés deviendraient illisibles.
PORTAL_VAULT_KEK=

# ─── Session ──────────────────────────────────────────────────────────────────
# [AUTO] clé de signature des sessions FastAPI.
SESSION_SECRET_KEY=

# ─── OIDC Keycloak ────────────────────────────────────────────────────────────
# [ADMIN] secret du client `workspace-portal` (realm yoops). Vide = OIDC désactivé.
OIDC_CLIENT_SECRET=

# ─── Harpocrate (laisser vide pour le backend inline) ─────────────────────────
HARPOCRATE_API_KEY=

# ─── Cloudflare Manager (exposition tunnel) ───────────────────────────────────
CFM_API_KEY=

# ─── Caddy — TLS wildcard DNS-01 (§F-30) ──────────────────────────────────────
# [ADMIN] token Cloudflare avec droit « Edit zone DNS » sur la zone yoops.org.
# OBLIGATOIRE en prod : sans lui, Caddy ne peut pas obtenir le certificat TLS et
# le portail n'est PAS joignable en HTTPS.
CF_API_TOKEN=
# [ADMIN] email de contact ACME (notifications d'expiration Let's Encrypt).
ACME_EMAIL=admin@yoops.org

# ─── Domaine de base ──────────────────────────────────────────────────────────
BASE_DOMAIN=pod.yoops.org

# ─── Authentification locale (fallback sans OIDC) ─────────────────────────────
# [AUTO] LOCAL_PASSWORD + LOCAL_PASSWORD_HASH générés au premier lancement (bcrypt).
LOCAL_USER=admin
LOCAL_PASSWORD=
LOCAL_PASSWORD_HASH=

# ─── Mode production ──────────────────────────────────────────────────────────
# false : cookie de session https_only (TLS obligatoire). NE PAS passer à true en prod.
DEV_MODE=false

# Racine des données (défaut : /data — ne modifier qu'en déploiement non standard)
# PORTAL_DATA_ROOT=/data
