# deploy/.env.example — copier en /data/.env, puis chmod 600 /data/.env
# Valeurs vides = fonctionnalité désactivée.
# dev-deploy.sh auto-génère SESSION_SECRET_KEY, POSTGRES_USER, POSTGRES_PASSWORD,
# DATABASE_URL et LOCAL_PASSWORD/LOCAL_PASSWORD_HASH.

# ─── Base de données ──────────────────────────────────────────────────────────
# Laissez vide : dev-deploy.sh génère des valeurs aléatoires au premier lancement.
POSTGRES_USER=
POSTGRES_PASSWORD=
# Construit automatiquement par dev-deploy.sh à partir des deux variables ci-dessus.
DATABASE_URL=

# ─── Vault ────────────────────────────────────────────────────────────────────
# Clé de chiffrement 32 bytes (64 chars hex). Générer : openssl rand -hex 32
# Ne JAMAIS laisser vide en production.
PORTAL_VAULT_KEK=

# ─── Session ──────────────────────────────────────────────────────────────────
# Clé de signature des sessions FastAPI (auto-générée par dev-deploy.sh)
SESSION_SECRET_KEY=

# OIDC Keycloak (laisser vide pour désactiver OIDC)
OIDC_CLIENT_SECRET=

# Harpocrate (laisser vide pour le backend inline)
HARPOCRATE_API_KEY=

# Cloudflare Manager
CFM_API_KEY=

# Caddy — DNS-01 wildcard (§F-30)
CF_API_TOKEN=
ACME_EMAIL=admin@example.com

# Domaine de base (ex: dev.yoops.org)
BASE_DOMAIN=dev.yoops.org

# Authentification locale (LOCAL_PASSWORD et LOCAL_PASSWORD_HASH auto-générés par dev-deploy.sh)
LOCAL_USER=admin
LOCAL_PASSWORD=
LOCAL_PASSWORD_HASH=

# Mode développement — désactive https_only sur le cookie de session (HTTP sans TLS)
# Mettre à false ou supprimer cette ligne en production avec TLS.
DEV_MODE=true

# Racine des données (défaut : /data — modifier uniquement si déploiement non standard)
# PORTAL_DATA_ROOT=/data
