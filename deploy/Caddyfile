{
    # API admin sur le réseau docker internal uniquement — port 2019 NON publié sur l'hôte.
    # 0.0.0.0 requis : le service `portal` (conteneur distinct) appelle http://caddy:2019
    # pour pousser les routes workspace en M6. 127.0.0.1 bloquerait cet accès inter-conteneurs.
    # Isolation : seuls `portal` et `caddy` partagent le réseau `internal` (cf. docker-compose.yml).
    admin 0.0.0.0:2019
}

# Portail principal : auth OIDC gérée par FastAPI lui-même
# Dev : tls internal (CA Caddy locale). Prod : remplacer par tls { dns cloudflare {$CF_API_TOKEN} }
{$BASE_DOMAIN} {
    tls internal
    reverse_proxy portal:8080
}

# Wildcard workspaces — routes dynamiques ajoutées par l'API admin en M6
# §F-33 : stub 404 fail-closed — jamais d'accès sans auth opérationnelle
# Dev : tls internal. Prod : remplacer par tls { dns cloudflare {$CF_API_TOKEN} }
*.{$BASE_DOMAIN} {
    tls internal
    # STUB M5 — sera remplacé par forward_auth + reverse_proxy en M6
    respond "Workspace introuvable (M6 non encore déployé)" 404
}
