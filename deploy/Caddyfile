{
    # API admin sur le réseau docker internal uniquement — port 2019 NON publié sur l'hôte.
    # 0.0.0.0 requis : le service `portal` (conteneur distinct) appelle http://caddy:2019
    # pour pousser les routes workspace en M6. 127.0.0.1 bloquerait cet accès inter-conteneurs.
    # Isolation : seuls `portal` et `caddy` partagent le réseau `internal` (cf. docker-compose.yml).
    admin 0.0.0.0:2019
}

# Portail principal : auth OIDC gérée par FastAPI lui-même
# Dev : HTTP plain (préfixe http:// désactive TLS + redirect auto de Caddy).
# Prod : retirer le préfixe http:// et ajouter tls { dns cloudflare {$CF_API_TOKEN} }
http://{$BASE_DOMAIN} {
    reverse_proxy portal:8080 {
        flush_interval -1
        transport http {
            read_timeout 0
            write_timeout 0
        }
    }
}

# Workspaces (ws-*.{$BASE_DOMAIN}) : routes ajoutées dynamiquement par le portail
# via l'API admin Caddy (forward_auth interne + reverse_proxy vers node_ip:host_port),
# sur le serveur srv0 ci-dessus (le seul à écouter :80).
#
# Pas de bloc statique *.{$BASE_DOMAIN} : il intercepterait les sous-domaines AVANT
# les routes dynamiques (ajoutées en fin de liste). Un sous-domaine sans route →
# 404 Caddy par défaut, ce qui préserve le fail-closed §F-33.
